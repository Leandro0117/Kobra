generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Negocio {
  id          Int         @id @default(autoincrement())
  nombre      String
  direccion   String?
  telefono    String?
  moneda      String
  creadoEn    DateTime    @default(now())
  usuarios    Usuario[]
  clientes    Cliente[]
  productos   Producto[]
  proveedores Proveedor[]
  insumos     Insumo[]
  ventas      Venta[]
  gastos      Gasto[]
}

model Usuario {
  id        Int      @id @default(autoincrement())
  negocio   Negocio  @relation(fields: [negocioId], references: [id])
  negocioId Int
  nombre    String
  email     String   @unique
  password  String
  rol       Rol
  ventas    Venta[]
  gastos    Gasto[]
  creadoEn  DateTime @default(now())
}

enum Rol {
  ADMIN
  VENDEDOR
}

model Cliente {
  id        Int      @id @default(autoincrement())
  negocio   Negocio  @relation(fields: [negocioId], references: [id])
  negocioId Int
  nombre    String
  telefono  String?
  notas     String?
  creadoEn  DateTime @default(now())
  ventas    Venta[]
}

model Producto {
  id        Int        @id @default(autoincrement())
  negocio   Negocio    @relation(fields: [negocioId], references: [id])
  negocioId Int
  nombre    String
  variantes Variante[]
}

model Variante {
  id         Int            @id @default(autoincrement())
  producto   Producto       @relation(fields: [productoId], references: [id])
  productoId Int
  nombre     String
  precio     Float
  costo      Float?
  detalles   DetalleVenta[]
}

model Venta {
  id         Int            @id @default(autoincrement())
  negocio    Negocio        @relation(fields: [negocioId], references: [id])
  negocioId  Int
  vendedor   Usuario        @relation(fields: [vendedorId], references: [id])
  vendedorId Int
  cliente    Cliente        @relation(fields: [clienteId], references: [id])
  clienteId  Int
  fecha      DateTime       @default(now())
  estado     EstadoVenta    @default(PENDIENTE)
  total      Float
  detalles   DetalleVenta[]
}

enum EstadoVenta {
  PENDIENTE
  POR_PAGAR
  PAGADO
  CANCELADO
}

model DetalleVenta {
  id             Int      @id @default(autoincrement())
  venta          Venta    @relation(fields: [ventaId], references: [id])
  ventaId        Int
  variante       Variante @relation(fields: [varianteId], references: [id])
  varianteId     Int
  cantidad       Float
  precioUnitario Float
  costoUnitario  Float?
}

// ===== Gastos (compra de insumos, proveedores, egresos en general) =====

model Proveedor {
  id        Int     @id @default(autoincrement())
  negocio   Negocio @relation(fields: [negocioId], references: [id])
  negocioId Int
  nombre    String
  telefono  String?
  gastos    Gasto[]
}

model Insumo {
  id        Int            @id @default(autoincrement())
  negocio   Negocio        @relation(fields: [negocioId], references: [id])
  negocioId Int
  nombre    String
  unidad    UnidadInsumo?
  precio    Float?
  detalles  DetalleGasto[]
}

enum UnidadInsumo {
  UNIDAD
  KG
  G
  L
  ML
  M
  CM
  PAQ
  CAJA
  DOC
}

enum CategoriaGasto {
  INSUMOS
  EQUIPAMIENTO
  SERVICIOS
  TRANSPORTE
  OTRO
}

model Gasto {
  id          Int            @id @default(autoincrement())
  negocio     Negocio        @relation(fields: [negocioId], references: [id])
  negocioId   Int
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])
  usuarioId   Int
  proveedor   Proveedor      @relation(fields: [proveedorId], references: [id])
  proveedorId Int
  categoria   CategoriaGasto
  fecha       DateTime       @default(now())
  total       Float
  detalles    DetalleGasto[]
}

model DetalleGasto {
  id             Int    @id @default(autoincrement())
  gasto          Gasto  @relation(fields: [gastoId], references: [id])
  gastoId        Int
  insumo         Insumo @relation(fields: [insumoId], references: [id])
  insumoId       Int
  cantidad       Float
  precioUnitario Float
}
